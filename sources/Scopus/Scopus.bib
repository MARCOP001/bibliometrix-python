@ARTICLE{HajiEsmailpoor2024,
	author = {HajiEsmailpoor, Zanyar and Fayazi, Alireza and Teymouri, Mohammadhossein and Tabnak, Peyman},
	title = {Role of long non-coding RNA ELFN1-AS1 in carcinogenesis},
