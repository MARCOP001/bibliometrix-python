	author = {Sasaki, Natsu and Shimazu, Taichi and Takeno, Hajime and Ogawa, Sayaka and Sawada, Utako and Tsutsumi, Akizumi and Imamura, Kotaro},
	title = {Implementation of an internet-based stress management program in micro- and small-sized enterprises: a study protocol for a pre-post feasibility study of the effectiveness-implementation hybrid type 2 trial},
