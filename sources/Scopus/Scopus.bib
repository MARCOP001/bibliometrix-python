	keywords = {Academic Performance; Adolescent; Child; Female; Humans; Male; Musculoskeletal Pain; Prevalence; Quality of Life; Refractive Errors; Shoulder Pain; Visual Acuity; academic achievement; academic grade; adolescent; Article; best corrected visual acuity; binocular status; binocular vision; controlled study; cross-sectional study; cycloplegic refraction; cycloplegic retinoscopy; eye examination; eye pain; Faces Pain Scale; female; headache; human; learning; low back pain; male; musculoskeletal pain; neck pain; questionnaire; refraction error; screen time; self reported  questionnaire; shoulder pain; vision test; visual disorder; visual system parameters; child; musculoskeletal pain; prevalence; quality of life; refraction error; visual acuity},
	correspondence_address = {H.-M.S. Thorud; National Centre for Optics, Vision and Eye Care, Department of Optometry, Radiography and Lighting Design, University of South-Eastern Norway, Kongsberg, Norway; email: hannemt@usn.no},
