@ARTICLE{Moe2024,
	author = {Moe, Jessica and Koh, Justin and Ma, Jennifer A. and Pei, Lulu X. and MacLean, Eleanor and Keech, James and Maguire, Kaitlyn and Ronsley, Claire and Doyle-Waters, Mary M. and Brubacher, Jeffrey R.},
	title = {Screening for harmful substance use in emergency departments: a systematic review},
	year = {2024},
	journal = {International Journal of Emergency Medicine},
	volume = {17},
