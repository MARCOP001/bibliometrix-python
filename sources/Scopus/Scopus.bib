@ARTICLE{Boven2024,
	author = {Boven, Annelies and Simin, Johanna and Andersson, Fredrik L. and Vlieghe, Erika and Callens, Steven and Zeebari, Zangin and Engstrand, Lars and Brusselaers, Nele},
	title = {Clostridioides difficile infection, recurrence and the associated healthcare consumption in Sweden between 2006 and 2019: a population-based cohort study},
	year = {2024},
	journal = {BMC Infectious Diseases},
