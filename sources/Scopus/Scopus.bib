@ARTICLE{Harrison2024,
	author = {Harrison, Hannah and Ip, Samantha and Renzi, Cristina and Li, Yangfan and Barclay, Matthew and Usher-Smith, Juliet and Lyratzopoulos, Georgios and Wood, Angela and Antoniou, Antonis C.},
	title = {Implementation and external validation of the Cambridge Multimorbidity Score in the UK Biobank cohort},
	year = {2024},
