@ARTICLE{Pomey2024,
	author = {Pomey, Marie-Pascale and Jutras-Aswad, Didier and Paquette, Jesseca and Saadi, Kamilla and Taguemout, Mélissa and Ikene, Dina-Liza and Arbour, Nathalie and Zertal, Amel and Fréjeau, Nathalie and Morin, Danielle and Ouellette, Jean-Sylvain and Alami Marrouni, Kanza and Duquette, Pierre},
	title = {Perceptions and engagement of patients with chronic conditions on the use of medical cannabis: a scoping review},
	year = {2024},
