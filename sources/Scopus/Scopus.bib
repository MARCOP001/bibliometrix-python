@ARTICLE{Takougang2024,
	author = {Takougang, Innocent and Lekeumo Cheuyem, Fabrice Zobel and Ze, Billy Ralph Sanding and Tsamoh, Forlemu Fabiola and Moneboulou, Hortense Mengong},
	title = {Awareness of standard precautions, circumstances of occurrence and management of occupational exposures to body fluids among healthcare workers in a regional level referral hospital (Bertoua, Cameroon)},
