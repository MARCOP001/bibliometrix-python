@ARTICLE{Lim2024,
	author = {Lim, Arum and Benjasirisan, Chitchanok and Liu, Xiaoyue and Ogungbe, Oluwabunmi and Himmelfarb, Cheryl Dennison and Davidson, Patricia and Koirala, Binu},
	title = {Social determinants of health and emergency department visits among older adults with multimorbidity: insight from 2010 to 2018 National Health Interview Survey},
	year = {2024},
	journal = {BMC Public Health},
