@ARTICLE{Lendino2024,
	author = {Lendino, Arianna and Castellanos, Adrian A. and Pigott, David M. and Han, Barbara A.},
	title = {A review of emerging health threats from zoonotic New World mammarenaviruses},
	year = {2024},
	journal = {BMC Microbiology},
	volume = {24},
	number = {1},
	doi = {10.1186/s12866-024-03257-w},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85189638546&doi=10.1186%2fs12866-024-03257-w&partnerID=40&md5=75712d964b5d54fa674bd4196dd65bcf},
	affiliations = {The George Washington University, Milken Institute for Public Health, Washington, 20052, DC, United States; Cary Institute of Ecosystem Studies, Millbrook, 12545, NY, United States; Institute for Health Metrics and Evaluation, University of Washington, 2301 5th Ave, Suite 600, Seattle, 98121, WA, United States; Department of Health Metrics Sciences, School of Medicine, University of Washington, Seattle, 98121, WA, United States},
	abstract = {Despite repeated spillover transmission and their potential to cause significant morbidity and mortality in human hosts, the New World mammarenaviruses remain largely understudied. These viruses are endemic to South America, with animal reservoir hosts covering large geographic areas and whose transmission ecology and spillover potential are driven in part by land use change and agriculture that put humans in regular contact with zoonotic hosts. We compiled published studies about Guanarito virus, Junin virus, Machupo virus, Chapare virus, Sabia virus, and Lymphocytic Choriomeningitis virus to review the state of knowledge about the viral hemorrhagic fevers caused by New World mammarenaviruses. We summarize what is known about rodent reservoirs, the conditions of spillover transmission for each of these pathogens, and the characteristics of human populations at greatest risk for hemorrhagic fever diseases. We also review the implications of repeated outbreaks and biosecurity concerns where these diseases are endemic, and steps that countries can take to strengthen surveillance and increase capacity of local healthcare systems. While there are unique risks posed by each of these six viruses, their ecological and epidemiological similarities suggest common steps to mitigate spillover transmission and better contain future outbreaks. © The Author(s) 2024.},
