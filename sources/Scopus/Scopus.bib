@ARTICLE{Piret2024,
	author = {Piret, Evelyne Marie and Milloy, M.-J. and Voon, Pauline and Choi, JinCheol and DeBeck, Kora and Hayashi, Kanna and Kerr, Thomas},
	title = {Denial of prescription pain medication among people who use drugs in Vancouver, Canada},
	year = {2024},
	journal = {Harm Reduction Journal},
