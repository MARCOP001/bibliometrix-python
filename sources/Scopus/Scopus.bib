@ARTICLE{Alkhaddo2024,
	author = {Alkhaddo, Jamil and Rung, Jillian M. and Khowaja, Ameer and Yin, Yue and Richards, Shannon B. and Drury-Gworek, Charlotte and Afreen, Samina and Rossi, Caitlan and Manzi, Susan},
	title = {Treatment approaches and costs associated with diabetes clinical metrics as measured by Healthcare Effectiveness Data and Information Set (HEDIS)},
