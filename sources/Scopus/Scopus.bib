@ARTICLE{Yi2024,
	author = {Yi, Zhanmiao and Mao, Yudan and He, Chenxuan and Zhang, Yantao and Zhou, Junwen and Feng, Xing Lin},
	title = {Medication adherence and costs of medical care among patients with Parkinson’s disease: an observational study using electronic medical records},
	year = {2024},
	journal = {BMC Public Health},
