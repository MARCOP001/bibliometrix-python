@ARTICLE{Chaaya2024,
	author = {Chaaya, Roni and Hallit, Rabih and Malaeb, Diana and Sakr, Fouad and Dabbous, Mariam and El Khatib, Sami and Fekih-Romdhane, Feten and Hallit, Souheil and Obeid, Sahar},
	title = {Moderating effect of self-esteem between perfectionism and avoidant restrictive food intake disorder among Lebanese adults},
	year = {2024},
