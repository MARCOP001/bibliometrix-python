}

@ARTICLE{Jairoun2024,
	author = {Jairoun, Ammar Abdulrahman and Al-Hemyari, Sabaa Saleh and Shahwan, Moyad and Zyoud, Samer H. and El-Dahiyat, Faris},
	title = {Community pharmacist-led point-of-care eGFR screening: early detection of chronic kidney disease in high-risk patients},
	year = {2024},
