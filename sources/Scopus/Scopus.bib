@ARTICLE{Murray2024,
	author = {Murray, Ruairi and Magendran, Erindaa and Chander, Neya and Lynch, Rosarie and O’Neill, Michelle and Devane, Declan and Smith, Susan M. and Mahtani, Kamal and Ryan, Máirín and Clyne, Barbara and Sharp, Melissa K.},
	title = {Co-design workshops to develop evidence synthesis summary formats for use by clinical guideline development groups},
	year = {2024},
