@ARTICLE{Levy2024,
	author = {Levy, Anne Marie and Grigorovich, Alisa and McMurray, Josephine and Quirt, Hannah and Ranft, Kaitlyn and Engell, Katia and Stewart, Steven and Astell, Arlene and Kokorelias, Kristina and Schon, Denise and Rogrigues, Kevin and Tsokas, Mario and Flint, Alastair J. and Iaboni, Andrea},
	title = {Implementation of the Dementia Isolation Toolkit in long-term care improves awareness but does not reduce moral distress amongst healthcare providers},
	year = {2024},
