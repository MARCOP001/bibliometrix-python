@ARTICLE{Fontaine2024,
	author = {Fontaine, Guillaume and Poitras, Marie-Eve and Sasseville, Maxime and Pomey, Marie-Pascale and Ouellet, Jérôme and Brahim, Lydia Ould and Wasserman, Sydney and Bergeron, Frédéric and Lambert, Sylvie D.},
