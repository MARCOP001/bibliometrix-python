	author = {Zhang, Jingya and Li, Haoran and Wei, Bincai and He, Rongxin and Zhu, Bin and Zhang, Ning and Mao, Ying},
	title = {Association between maternal health service utilization and under-five mortality rate in China and its provinces, 1990–2017},
	year = {2024},
	journal = {BMC Pregnancy and Childbirth},
