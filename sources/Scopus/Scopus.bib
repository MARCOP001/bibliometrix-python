	volume = {24},
	number = {1},
	doi = {10.1186/s12884-024-06471-6},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85189812463&doi=10.1186%2fs12884-024-06471-6&partnerID=40&md5=880b31133d66050c62dde53c08e17041},
	affiliations = {Department of Obstetrics and Gynecology, Los Angeles County + University of Southern California (LAC+USC) Medical Center, Keck School of Medicine of University of Southern California, 1200 N State Street, Los Angeles, 90033, CA, United States; Keck School of Medicine of University of Southern California, Department of Population and Public Health Sciences, Los Angeles, CA, United States; Division of Maternal-Fetal Medicine, Department of Obstetrics and Gynecology, University of Southern California, Los Angeles, CA, United States},
	abstract = {Background: Preterm birth is a leading cause of infant morbidity and mortality worldwide. The burden of prematurity underscores the need for effective risk reduction strategies. The purpose of this study is to evaluate the efficacy of progesterone therapy, both intramuscular 17-α-hydroxyprogesterone caproate (IM 17-OHPC) and vaginal progesterone, in the prevention of recurrent spontaneous preterm birth (sPTB). The co-primary outcomes included: recurrent spontaneous PTB < 37 and < 34 weeks’ gestation. Methods: This retrospective cohort study included 637 pregnant patients that delivered at any of the three hospitals within the Los Angeles County healthcare system between October 2015 and June 2021. We compared frequencies of measured variables between each of the progesterone treated groups to no treatment using Pearson chi-squared tests and independent t-tests for categorical and continuous variables, respectively. We estimated crude and adjusted associations between each specific treatment (versus no treatment) and primary outcomes using logistic regression. Results: Recurrent sPTB < 37 weeks’ gestation occurred in 22.3% (n = 64) of those in the no treatment group, 29.1% (n = 86, p =.077) in the 17-OHPC group, and 14.3% (n = 6, p = 0.325) in the vaginal progesterone group. Recurrent sPTB < 34 weeks’ gestation was 6.6% (n = 19) in the no treatment group, 11.8% (n = 35, p =.043) in the 17-OHPC group, and 7.1% (n = 3, p = 1) in the vaginal progesterone group. Among all participants, neither 17-OHPC nor vaginal progesterone was significantly associated with a reduction in recurrent sPTB at any time point. Among those with a short cervix, IM 17-OHPC was positively associated with recurrent sPTB < 37 weeks’ gestation (aOR 5.61; 95% CI 1.16, 42.9). Conclusions: Progesterone therapy of any type did not reduce the risk of recurrent sPTB < 34 or < 37 weeks’ gestation compared to no progesterone therapy. © The Author(s) 2024.},
	author_keywords = {IM 17-alpha hydroxyprogesterone caproate; Prematurity; Spontaneous preterm delivery; Vaginal progesterone},
	keywords = {17 alpha-Hydroxyprogesterone Caproate; Female; Humans; Infant, Newborn; Infant, Premature; Pregnancy; Premature Birth; Progesterone; Retrospective Studies; hydroxyprogesterone caproate; progesterone; hydroxyprogesterone caproate; progesterone; adult; Apgar score; Article; cohort analysis; female; gestational age; gestational diabetes; human; logistic regression analysis; neonatal intensive care unit; pregnancy outcome; prematurity; retrospective study; risk factor; newborn; pregnancy; prematurity},
