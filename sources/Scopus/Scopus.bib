@ARTICLE{Abdolalipour2024,
	author = {Abdolalipour, Somayeh and Abbasalizadeh, Shamsi and Mohammad-Alizadeh-Charandabi, Sakineh and Abbasalizadeh, Fatemeh and Jahanfar, Shayesteh and Asghari Jafarabadi, Mohammad and Abdollahi, Kosar and Mirghafourvadsnd, Mojgan},
	title = {Translation and measurement properties of pregnancy and childbirth questionnaire in Iranian postpartum women},
	year = {2024},
