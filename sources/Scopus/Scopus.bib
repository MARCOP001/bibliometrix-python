@ARTICLE{Frank2024,
	author = {Frank, Hannah E. and Guzman, Linda E. and Ayalasomayajula, Shivani and Albanese, Ariana and Dunklee, Brady and Harvey, Matthew and Bouchard, Kelly and Vadiveloo, Maya and Yaroch, Amy L. and Scott, Kelli and Tovar, Alison},
	title = {Developing and testing a produce prescription implementation blueprint to improve food security in a clinical setting: a pilot study protocol},
