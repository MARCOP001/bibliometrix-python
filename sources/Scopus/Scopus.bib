}

@ARTICLE{Peter2024,
	author = {Peter, Sophie and Oberröhrmann, Charlotte and Pfaff, Holger and Lehmann, Clara and Schmidt-Hellerau, Kirsten and Brandes, Vanessa and Leisse, Charlotte and Lindemann, Christoph Heinrich and Ihle, Peter and Küpper-Nybelen, Jutta and Hagemeier, Anna and Scholten, Nadine},
