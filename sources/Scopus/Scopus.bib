@ARTICLE{Montoya2024,
	author = {Montoya, Iván D. and Watson, Colleen and Aldridge, Arnie and Ryan, Danielle and Murphy, Sean M. and Amuchi, Brenda and McCollister, Kathryn E. and Schackman, Bruce R. and Bush, Joshua L. and Speer, Drew and Harlow, Kristin and Orme, Stephen and Zarkin, Gary A. and Castry, Mathieu and Seiber, Eric E. and Barocas, Joshua A. and Linas, Benjamin P. and Starbird, Laura E.},
	title = {Cost of start-up activities to implement a community-level opioid overdose reduction intervention in the HEALing Communities Study},
