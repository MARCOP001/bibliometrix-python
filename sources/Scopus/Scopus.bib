@ARTICLE{Zampatti2024,
	author = {Zampatti, Noemi and Bonato, Irene and Calandrino, Andrea and Saffioti, Carolina and Parodi, Alessandro and Brigati, Giorgia and Minghetti, Diego and Ramenghi, Luca Antonio},
	title = {Severe cellulitis from methicillin-resistant Staphylococcus aureus (MRSA) in a couple of preterm twins: a case report},
	year = {2024},
	journal = {Italian Journal of Pediatrics},
	volume = {50},
	number = {1},
	doi = {10.1186/s13052-024-01659-0},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85190775496&doi=10.1186%2fs13052-024-01659-0&partnerID=40&md5=7716d456ae2343cd31be69d87e5b110a},
	affiliations = {Department of Neuroscience, Rehabilitation, Ophtalmology, Genetics, Maternal and Child Health, University of Genoa, Genoa, 16132, Italy; Department of Maternal and Neonatal Health, Neonatal Intensive Care Unit, IRCCS Istituto Giannina Gaslini, Genoa, 16147, Italy; Department of Pediatrics, Infectious Disease Unit, IRCCS Istituto Giannina Gaslini, Genoa, 16147, Italy},
	abstract = {Background: Preterms are at risk of systemic infections as the barrier function of their immature skin is insufficient. The long period of hospitalization and the huge number of invasive procedures represent a risk factor for complications. Among the nosocomial infections of the skin, methicillin-resistant Staphylococcus aureus (MRSA) is associated with significant morbidity and mortality. We report a clinical case of cellulitis and abscess in two preterm twins caused by MRSA in a tertiary level Neonatal Intensive Care Unit (NICU). Case presentation: Two preterm female babies developed cellulitis from MRSA within the first month of extrauterine life. The first one (BW 990 g) showed signs of clinical instability 4 days before the detection of a hyperaemic and painful mass on the thorax. The second one (BW 1240 g) showed signs of clinical instability contextually to the detection of an erythematous, oedematous and painful area in the right submandibular space. In both cases the diagnosis of cellulitis was confirmed by ultrasound. A broad spectrum, multidrug antimicrobial therapy was administered till complete resolution. Conclusions: Due to the characteristic antibiotic resistance of MRSA and the potential complications of those infections in such delicate patients, basic prevention measures still represent the key to avoid the spreading of neonatal MRSA infections in NICUs, which include hand hygiene and strict precautions, as well as screening of patients for MRSA on admission and during hospital stay, routine prophylactic topical antibiotic of patients, enhanced environmental cleaning, cohorting and isolation of positive patients, barrier precautions, avoidance of ward crowding, and, in some units, surveillance, education and decolonization of healthcare workers and visiting parents. © The Author(s) 2024.},
	author_keywords = {Abscess; Case report; Cellulitis; MRSA; Preterm infants; Skin infection},
	keywords = {Cellulitis; Cross Infection; Female; Humans; Infant, Newborn; Infection Control; Intensive Care Units, Neonatal; Methicillin-Resistant Staphylococcus aureus; Staphylococcal Infections; ampicillin; C reactive protein; cotrimoxazole; fluconazole; gentamicin; meropenem; mupirocin; piperacillin plus tazobactam; rifampicin; teicoplanin; vancomycin; abscess; antibiotic sensitivity; antifungal prophylaxis; antimicrobial therapy; Article; birth weight; blood cell count; blood culture; bradycardia; case report; cellulitis; cesarean section; clinical article; disease course; drug monitoring; drug withdrawal; echography; edema; erythema; female; human; human tissue; hyperemia; infection prevention; infectious meningitis; jaw pain; leukocytosis; lumbar puncture; methicillin resistant Staphylococcus aureus; methicillin resistant Staphylococcus aureus infection; microbiological examination; neonatal intensive care unit; newborn; newborn sepsis; nose smear; patient isolation; prematurity; prophylaxis; remission; respiratory distress; submandibular space edema; tertiary care center; thoracic tumor; treatment duration; twin twin transfusion syndrome; twins; cellulitis; cross infection; infection control; methicillin resistant Staphylococcus aureus; procedures; Staphylococcus infection},
