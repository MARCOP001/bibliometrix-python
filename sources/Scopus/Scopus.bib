	keywords = {Adolescent; Adult; China; Cross-Sectional Studies; Digital Health; Health Literacy; Humans; Internet; Surveys and Questionnaires; Telemedicine; adolescent; adult; China; cross-sectional study; health literacy; human; Internet; questionnaire; telemedicine},
