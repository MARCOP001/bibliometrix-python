@ARTICLE{Durão2024,
	author = {Durão, Solange and Effa, Emmanuel and Mbeye, Nyanyiwe and Mthethwa, Mashudu and McCaul, Michael and Naude, Celeste and Brand, Amanda and Blose, Ntombifuthi and Mabetha, Denny and Chibuzor, Moriam and Arikpo, Dachi and Chipojola, Roselyn and Kunje, Gertrude and Vandvik, Per Olav and Esu, Ekpereonne and Lewin, Simon and Kredo, Tamara},
	title = {Using a priority setting exercise to identify priorities for guidelines on newborn and child health in South Africa, Malawi, and Nigeria},
