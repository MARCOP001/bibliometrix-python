@ARTICLE{Orellana2024,
	author = {Orellana, Minerva and DSouza, Karen. N and Yap, Jane Q. and Sriganeshan, Abhirami and Jones, M. Elena and Johnson, Charis and Allyse, Megan and Venable, Sateria and Stewart, Elizabeth A. and Enders, Felicity and Balls-Berry, Joyce E.},
	title = {“In our community, we normalize pain”: discussions around menstruation and uterine fibroids with Black women and Latinas},
	year = {2024},
	journal = {BMC Women's Health},
	volume = {24},
	number = {1},
	doi = {10.1186/s12905-024-03008-z},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85190301625&doi=10.1186%2fs12905-024-03008-z&partnerID=40&md5=6d1467251edf4504a2415f8647bc0785},
	affiliations = {Department of Obstetrics and Gynecology, University of Washington, Seattle, WA, United States; Center for Clinical and Translational Science, Mayo Clinic, Rochester, MN, United States; Department of Quantitative Health Sciences Research, Mayo Clinic, Rochester, MN, United States; University of Miami, Miami, FL, United States; Department of Neurology, Washington University School of Medicine, 4488 Forest Park, St. Louis, 63108, MO, United States; Program in Biomedical Ethics Research, Mayo Clinic, Rochester, MN, United States; Department of Obstetrics and Gynecology, Mayo Clinic, Rochester, MN, United States; The Fibroid Foundation, Bethesda, MD, United States; Division of Reproductive Endocrinology, Department of Obstetrics & amp; Gynecology, Mayo Clinic, Rochester, MN, United States; Mayo Clinic College of Medicine & amp; Science, Rochester, MN, United States; Division of Clinical Trials and Biostatistics, Mayo Clinic, Rochester, MN, United States},
	abstract = {Background: Uterine fibroids are non-cancerous neoplasms that arise from the uterus affecting over 75% of women. However, there is a disparity with Black women having an increased prevalence of nearly 80%. Black women also experience increased symptom burden, including younger age at the time of diagnosis and increased number and volume of fibroids. Less is known about other ethnoracially diverse women such as Latinas and the potential cultural impacts on fibroid burden and treatment. Methods: Community engagement studios were conducted to facilitate discussions with stakeholders on their uterine fibroid and menstruation experience. We recruited Black women (n = 6) diagnosed with uterine fibroids and Latinas (n = 7) without uterine fibroids. We held two virtual community engagement studios split by uterine fibroid diagnosis. The studios were not audio recorded and notes were taken by four notetakers. The notes were thematically analyzed in Atlas.ti using content analysis. Results: Participants felt there was a lack of discussion around menstruation overall, whether in the home or school settings. This lack of menstruation education was pronounced when participants had their first menstruation experience, with many unaware of what to expect. This silence around menstruation led to a normalization of painful menstruation symptoms. When it came to different treatment options for uterine fibroids, some women wanted to explore alternative treatments but were dismissed by their healthcare providers. Many participants advocated for having discussions with their healthcare provider about life goals to discuss different treatment options for their uterine fibroids. Conclusion: Despite uterine fibroid diagnosis, there is silence around menstruation. Menstruation is a normal biological occurrence and needs to be discussed to help prevent delayed diagnosis of uterine fibroids and possibly other gynecological disorders. Along with increased discussions around menstruation, further discussion is needed between healthcare providers and uterine fibroid patients to explore appropriate treatment options. © The Author(s) 2024.},
	author_keywords = {Black women; Community-engaged research; Health disparities; Latinas; Leiomyomas; Menstruation; Taboo; Uterine fibroids; Women’s health},
	keywords = {Black People; Dysmenorrhea; Female; Hispanic or Latino; Humans; Leiomyoma; Menstruation; adult; African American; Article; Black person; clinical article; community; content analysis; controlled study; dysmenorrhea; female; health care personnel; health disparity; Hispanic; home; human; leiomyoma; menarche; menstruation; middle aged; prevalence; school; stakeholder engagement; symptom burden; taboo; thematic analysis; uterus myoma; Black person; complication; dysmenorrhea; leiomyoma},
