@ARTICLE{Ferrari2024,
	author = {Ferrari, D. and Violante, T. and Addison, P. and Perry, W.R.G. and Merchea, A. and Kelley, S.R. and Mathis, K.L. and Dozois, E.J. and Larson, D.W.},
	title = {Robotic resection of presacral tumors},
	year = {2024},
	journal = {Techniques in Coloproctology},
	volume = {28},
	number = {1},
	doi = {10.1007/s10151-024-02922-6},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85191084348&doi=10.1007%2fs10151-024-02922-6&partnerID=40&md5=33ae9d6876d32160bb7ef890ca0c8040},
	affiliations = {Division of Colon and Rectal Surgery, Mayo Clinic, 200 First St. Southwest, Rochester, 55905, MN, United States; Division of Colon and Rectal Surgery, Mayo Clinic, Jacksonville, FL, United States; General Surgery Residency Program, University of Milan, Milan, Italy; School of General Surgery, Alma Mater Studiorum Università di Bologna, Bologna, Italy},
	abstract = {Background: Presacral tumors are a rare entity typically treated with an open surgical approach. A limited number of minimally invasive resections have been described. The aim of the study is to evaluate the safety and efficacy of roboticresection of presacral tumors. Methods: This is a retrospective single system analysis, conducted at a quaternary referral academic healthcare system, and included all patients who underwent a robotic excision of a presacral tumor between 2015 and 2023. Outcomes of interest were operative time, estimated blood loss, complications, length of stay, margin status, and recurrence rates. Results: Sixteen patients (11 females and 5 males) were included. The median age of the cohort was 51 years (range 25–69 years). The median operative time was 197 min (range 98–802 min). The median estimated blood loss was 40 ml, ranging from 0 to 1800 ml, with one patient experiencing conversion to open surgery after uncontrolled hemorrhage. Urinary retention was the only postoperative complication that occurred in three patients (19%) and was solved within 30 days in all cases. The median length of stay was one day (range 1–6 days). The median follow-up was 6.7 months (range 1–110 months). All tumors were excised with appropriate margins, but one benign and one malignant tumor recurred (12.5%). Ten tumors were classified as congenital (one was malignant), two were mesenchymal (both malignant), and five were miscellaneous (one malignant). Conclusions: Robotic resection of select presacral pathology is feasible and safe. Further studies must be conducted to determine complication rates, outcomes, and long-term safety profiles. © Springer Nature Switzerland AG 2024.},
	author_keywords = {Minimally invasive surgery; Presacral tumors; Robotic surgery; Tailgut cysts},
	keywords = {Adult; Aged; Blood Loss, Surgical; Female; Humans; Length of Stay; Male; Margins of Excision; Middle Aged; Neoplasm Recurrence, Local; Operative Time; Pelvic Neoplasms; Postoperative Complications; Retrospective Studies; Robotic Surgical Procedures; Treatment Outcome; leuprorelin; adult; aged; angiomyxoma; Article; blood transfusion; cancer radiotherapy; cancer surgery; clinical article; cohort analysis; controlled study; conversion to open surgery; cyst; cystadenoma; epidermoid cyst; feasibility study; female; follicular dendritic cell sarcoma; follow up; hamartoma; histopathology; human; human tissue; intermittent catheterization; intraoperative period; leiomyosarcoma; length of stay; local excision; male; myelolipoma; myxoma; operation duration; operative blood loss; partial vaginectomy; patient safety; pelvic bone tumor; pelvic pain; peritoneum mesothelioma; preoperative evaluation; presacral tumor; recurrence risk; reoperation; retrograde ejaculation; retrospective study; robot assisted surgery; salpingooophorectomy; sexual dysfunction; solitary fibrous tumor; surgical margin; surgical technique; tailgut cyst; therapy effect; treatment outcome; tumor classification; tumor recurrence; urinary dysfunction; urine retention; vaginectomy; length of stay; middle aged; operation duration; operative blood loss; pelvis tumor; postoperative complication; procedures},
