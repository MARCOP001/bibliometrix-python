@ARTICLE{Ingvarsson2024,
	author = {Ingvarsson, Emelie and Schildmeijer, Kristina and Hagerman, Heidi and Lindberg, Catharina},
	title = {“Being the main character but not always involved in one’s own care transition” - a qualitative descriptive study of older adults’ experiences of being discharged from in-patient care to home},
	year = {2024},
	journal = {BMC Health Services Research},
	volume = {24},
