@ARTICLE{Randriamboarison2024,
	author = {Randriamboarison, Doriane and Fustec, Elisa and Enderlé, Isabelle and Yverneau, Mathilde and Le Breton, Karine and Lassel, Linda and Mazille-Orfanos, Nadia and Pladys, Patrick},
	title = {Qualitative analysis of mothers’ perception related to the delivery of information regarding preterm births},
