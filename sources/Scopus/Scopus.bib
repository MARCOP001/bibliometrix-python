@ARTICLE{Alemu2024,
	author = {Alemu, Chekol and Wudu, Habitamu and Lakew, Samuel},
	title = {Fear of childbirth and its associated factors among pregnant women in Dejen Woreda, East Gojjam Zone, Northwest Ethiopia: a community-based cross-sectional study},
	year = {2024},
