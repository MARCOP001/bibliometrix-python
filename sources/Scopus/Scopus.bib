@ARTICLE{Bune2024,
	author = {Bune, Girma Tenkolu},
	title = {Low-level physical activity predictors among adults living with HIV in Ethiopia’s southern region, focusing on work, transportation, and recreation domains: unmatched case-control study},
	year = {2024},
	journal = {BMC Sports Science, Medicine and Rehabilitation},
	volume = {16},
	number = {1},
	doi = {10.1186/s13102-024-00860-2},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85189439976&doi=10.1186%2fs13102-024-00860-2&partnerID=40&md5=18e3cafa2a3138d09d186964984a10c7},
	affiliations = {School of Public Health (SPH), College of Medicine and Health Science (CMH), Dilla University (DU), Dilla, Ethiopia},
	abstract = {Background: Low-level physical activity (LLPA) is crucial for the well-being of adults living with HIV (PLWHs). However, many do not engage in enough physical activity, leading to adverse health outcomes. Identifying the determinants of LLPA can aid in developing effective interventions. Despite this, Ethiopia lacks evidence on this topic. This study aimed to identify predictors of LLPA among PLWHs in the Gedeo zone, located in southern Ethiopia. Methods: An unmatched case-control study was conducted on PLWHs in the Gedeo zone who visited two hospitals and healthcare institutions between December 29th, 2017 and January 22nd, 2019. Respondents were classified into three categories based on their total physical activity levels: high, moderate, and low. Cases were defined as those meeting the criteria for LLPA, while controls were those who did not fall under the cases category. Data was collected using the WHO Stepwise surveillance tool and analyzed using Epidata v3.1 templates and SPSS v22. Predictor variables with a P-value < 0.25 in bivariable analysis and < 0.05 with a 95% confidence interval in multivariable analysis were selected. Results: The study involved 633 HIV-positive adults, with a response rate of 92.41%. Most participants were under 34 years old, with an average age of 36.47±(9.055) for cases and 36.38±(8.389) for controls. The multivariable analysis revealed that educational status (AOR = 4.85, P = 0.02, 95%CI (1.28–18.44)), sex (AOR = 0.24, P = 0.04, 95%CI (0.07–0.90)), duration on ART being exposed for 1–4 Years (AOR = 0.12, P < 0.001, 95%CI (0.03–0.44)) and being exposed for 5–9 Years (AOR = 0.03, P < 0.001, 95%CI (0.01–0.16)), and former alcohol use (AOR = 0.11, P < 0.01, 95%CI (0.02–0.56) were significant predictors of LLPA performance. Conclusions: The study concluded that educational status, sex, ART duration, and past alcohol use are key determinants of LLPA performance among PLWHs in southern Ethiopia. This suggests that policymakers should implement public health campaigns to promote healthy habits, particularly low-level physical activity, among PLWHs. © The Author(s) 2024.},
	author_keywords = {And africa; Cases; Controls; Dilla university; Ethiopia; Gedeo Zone; HLPA; LLPA performance; MLPA; PLWH; Southern ethiopia; TPA},
	keywords = {abacavir; antiretrovirus agent; CD4 antigen; cholesterol; efavirenz; high density lipoprotein; lamivudine; low density lipoprotein; margarine; nevirapine; sugar; tenofovir disoproxil; triacylglycerol; vegetable oil; zidovudine; adult; Africa; alcohol consumption; antiretroviral therapy; Article; case control study; controlled study; disease surveillance; DNA template; educational status; Ethiopia; female; health care; human; Human immunodeficiency virus; Human immunodeficiency virus infected patient; Human immunodeficiency virus infection; low level physical activity; major clinical study; male; multiplex ligation dependent probe amplification; multiplex polymerase chain reaction; multivariate analysis; outcome assessment; physical activity; recreation; sex allocation; traffic and transport; treatment duration; work; World Health Organization},
