	keywords = {Child; Decision Making; Female; Humans; Infant, Newborn; Kenya; Male; Maternal Health; Maternal Health Services; Pregnancy; Qualitative Research; adult; Article; attitude to health; empowerment; exploratory research; health care delivery; health care utilization; health service; help seeking behavior; human; male; maternal mortality; maternal welfare; medical decision making; patient autonomy; personal experience; prenatal care; primary medical care; purposive sample; qualitative analysis; self esteem; social network; thematic analysis; article; child; child health care; conceptual framework; controlled study; decision making; empowerment; female; gender equity; household; interview; live birth; maternal care; maternal health service; mortality rate; newborn mortality; obstetric delivery; pregnant woman; qualitative research; reproductive health},
