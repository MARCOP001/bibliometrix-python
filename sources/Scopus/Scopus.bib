@ARTICLE{Abensur Vuillaume2024,
	author = {Abensur Vuillaume, Laure and Goffoy, Jonathan and Dubois, Nadège and Almoyner, Nathacha and Bardet, Cécile and Dubreucq, Evelyne and Klenkenberg, Sophie and Donneau, Anne-Françoise and Dib, Camille and Ghuysen, Alexandre},
	title = {Collaborative virtual reality environment in disaster medicine: moving from single player to multiple learners},
