@ARTICLE{Endalamaw2024,
	author = {Endalamaw, Aklilu and Khatri, Resham B and Erku, Daniel and Zewdie, Anteneh and Wolka, Eskinder and Nigatu, Frehiwot and Assefa, Yibeltal},
	title = {Barriers and strategies for primary health care workforce development: synthesis of evidence},
	year = {2024},
