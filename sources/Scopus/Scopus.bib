	correspondence_address = {X. He; School of Medicine and Health Management, Guizhou Medical University, Guiyang, China; email: hexun224@gmc.edu.cn; L.P. Wong; Department of Social and Preventive Medicine, Faculty of Medicine, Universiti Malaya, Kuala Lumpur, Malaysia; email: wonglp@ummc.edu.my; T. Loganathan; Department of Social and Preventive Medicine, Faculty of Medicine, Universiti Malaya, Kuala Lumpur, Malaysia; email: drtharani@ummc.edu.my},
