@ARTICLE{Manirajan2024,
	author = {Manirajan, Priya and Sivanandy, Palanisamy and Ingle, Pravinkumar Vishwanath},
	title = {Enhancing knowledge, attitude, and perceptions towards fall prevention among older adults: a pharmacist-led intervention in a primary healthcare clinic, Gemas, Malaysia},
	year = {2024},
	journal = {BMC Geriatrics},
