@ARTICLE{Michels-Zetsche2024,
	author = {Michels-Zetsche, Julia D. and Schubert-Haack, Janina and Tanck, Katrin and Neetz, Benjamin and Iberl, Gabriele and Müller, Michael and Kempa, Axel and Joves, Biljana and Rheinhold, Andreas and Ghiani, Alessandro and Tsitouras, Konstantinos and Schneider, Armin and Rauch, Christoph and Gehrig, Patrick and Biehler, Elena and Fleischauer, Thomas and Britsch, Simone and Frerk, Timm and Szecsenyi, Joachim and Herth, Felix J. F. and Trudzinski, Franziska C.},
