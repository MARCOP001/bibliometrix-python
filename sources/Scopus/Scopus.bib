@ARTICLE{McNaught2024,
	author = {McNaught, Emma and Reale, Sophie and Bourke, Liam and Brown, Janet E. and Collinson, Michelle and Day, Florence and Hewison, Jenny and Farrin, Amanda J. and Ibeggazene, Saïd and Innes, Aidan Q. and Mason, Ellen and Meads, David and Scope, Alison and Taylor, Chris and Taylor, Steph JC. and Turner, Rebecca R. and Rosario, Derek J.},
	title = {Supported exercise TrAining for Men wIth prostate caNcer on Androgen deprivation therapy (STAMINA): study protocol for a randomised controlled trial of the clinical and cost-effectiveness of the STAMINA lifestyle intervention compared with optimised usual care, including internal pilot and parallel process evaluation},
	year = {2024},
