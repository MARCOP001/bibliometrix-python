	correspondence_address = {S.P. Reis; Digital Medical Technologies, Holon Institute of Technology, Holon, 52 Golomb St, POB 305, 5810201, Israel; email: shmuelre@hit.ac.il},
	publisher = {BioMed Central Ltd},
