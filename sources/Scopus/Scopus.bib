@ARTICLE{Cortegiani2024,
	author = {Cortegiani, Andrea and Battaglini, Denise and Amato, Giovanna and Behr, Astrid Ursula and Donadello, Katia and Einav, Sharon and Frigo, Maria Grazia and Fullin, Giorgio and Giannini, Alberto and Ippolito, Mariachiara and Marozzi, Franco and Monzani, Roberta and Monti, Gianpaola and Schultz, Marcus J. and Torrano, Vito and Villa, Gianluca and Giarratano, Antonino},
	title = {Dissemination of clinical and scientific practice through social media: a SIAARTI consensus-based document},
	year = {2024},
	journal = {Journal of Anesthesia, Analgesia and Critical Care},
