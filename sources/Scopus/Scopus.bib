@ARTICLE{Saturno-Hernández2024,
	author = {Saturno-Hernández, Pedro and Moreno-Zegbe, Estephania and Poblano-Verastegui, Ofelia and Torres-Arreola, Laura del Pilar and Bautista-Morales, Arturo C. and Maya-Hernández, Cynthya and Uscanga-Castillo, Juan David and Flores-Hernández, Sergio and Gómez-Cortez, Patricia María and Vieyra-Romero, Waldo Iván},
	title = {Hospital care direct costs due to ambulatory care sensitive conditions related to diabetes mellitus in the Mexican public healthcare system},
