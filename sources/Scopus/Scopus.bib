@ARTICLE{Möckli2024,
	author = {Möckli, Nathalie and Simon, Michael and Denhaerynck, Kris and Trutschel, Diana and Martins, Tania and Meyer-Massetti, Carla and Zúñiga, Franziska},
	title = {How external and agency characteristics are related to coordination in homecare – findings of the national multicenter, cross-sectional SPOTnat study},
	year = {2024},
	journal = {BMC Health Services Research},
	volume = {24},
