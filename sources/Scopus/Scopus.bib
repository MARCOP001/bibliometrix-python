	keywords = {Adolescent; Adult; Cross-Sectional Studies; Delivery, Obstetric; Ethiopia; Fear; Female; Humans; Parturition; Pregnancy; Pregnant Women; Prevalence; Surveys and Questionnaires; Young Adult; adolescent; adult; birth; cross-sectional study; epidemiology; Ethiopia; fear; female; human; obstetric delivery; pregnancy; pregnant woman; prevalence; psychology; questionnaire; young adult},
