	author = {Newson, Rachel S. and Spaepen, Erik and Liao, Birong and Bower, Julie and Bhattacharya, Indranil and Artime, Esther and Polonsky, William},
	title = {Understanding suboptimal insulin use in type 1 and 2 diabetes: a cross-sectional survey of healthcare providers who treat people with diabetes},
	year = {2024},
