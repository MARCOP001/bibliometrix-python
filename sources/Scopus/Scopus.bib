@ARTICLE{Moger2024,
	author = {Moger, Tron Anders and Holte, Jon Helgheim and Amundsen, Olav and Haavaag, Silje Bjørnsen and Edvardsen, Anne and Bragstad, Line Kildal and Hellesø, Ragnhild and Tjerbo, Trond and Vøllestad, Nina Køpke},
	title = {Associations between outpatient care and later hospital admissions for patients with chronic obstructive pulmonary disease - a registry study from Norway},
