	correspondence_address = {N. Pfeuffer; Section Epidemiology of Health Care and Community Health, Institute for Community Medicine, University Medicine Greifswald, Greifswald, Ellernholzstr. 1-2, 17489, Germany; email: nils.pfeuffer@med.uni-greifswald.de},
