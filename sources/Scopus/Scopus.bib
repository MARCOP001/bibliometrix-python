	keywords = {Antitubercular Agents; Cross-Sectional Studies; Delivery of Health Care; Ethiopia; HIV Infections; Humans; Male; Retrospective Studies; Treatment Outcome; Tuberculosis; tuberculostatic agent; complication; cross-sectional study; Ethiopia; health care delivery; human; Human immunodeficiency virus infection; male; retrospective study; treatment outcome; tuberculosis},
