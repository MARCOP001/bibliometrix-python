	year = {2024},
	journal = {BMC Medical Education},
	volume = {24},
	number = {1},
	doi = {10.1186/s12909-024-05336-y},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85189790144&doi=10.1186%2fs12909-024-05336-y&partnerID=40&md5=161edadbf9814507d4fa9b6ff1a92c37},
	affiliations = {Atenea Research. FISABIO, Alicante, Spain; Universidad Miguel Hernández, Elche, Spain; Faculty of Health and Social Care, LAB University of Applied Sciences, Lappeenranta, Finland; NOVA National School of Public Health, Public Health Research Centre, Comprehensive Health Research Center, CHRC, NOVA University Lisbon, Lisbon, Portugal; Escola Paulista de Enfermagem, Universidade Federal de São Paulo, São Paulo, Brazil; Wiesbaden Institute for Healthcare Economics and Patient Safety (WiHelP), RheinMain UAS, Wiesbaden, Germany},
	abstract = {Background: When healthcare students witness, engage in, or are involved in an adverse event, it often leads to a second victim experience, impacting their mental well-being and influencing their future professional practice. This study aimed to describe the efforts, methods, and outcomes of interventions to help students in healthcare disciplines cope with the emotional experience of being involved in or witnessing a mistake causing harm to a patient during their clerkships or training. Methods: This systematic review followed the PRISMA guidelines and includes the synthesis of eighteen studies, published in diverse languages from 2011 to 2023, identified from the databases MEDLINE, EMBASE, SCOPUS and APS PsycInfo. PICO method was used for constructing a research question and formulating eligibility criteria. The selection process was conducted through Rayyan. Titles and abstracts of were independently screened by two authors. The critical appraisal tools of the Joanna Briggs Institute was used to assess the risk of bias of the included studies. Results: A total of 1354 studies were retrieved, 18 met the eligibility criteria. Most studies were conducted in the USA. Various educational interventions along with learning how to prevent mistakes, and resilience training were described. In some cases, this experience contributed to the student personal growth. Psychological support in the aftermath of adverse events was scattered. Conclusion: Ensuring healthcare students’ resilience should be a fundamental part of their training. Interventions to train them to address the second victim phenomenon during their clerkships are scarce, scattered, and do not yield conclusive results on identifying what is most effective and what is not. © The Author(s) 2024.},
	author_keywords = {Adverse events; Patient safety; Resilience; Second victims; Students},
	keywords = {Delivery of Health Care; Humans; Learning; Mental Health; Resilience, Psychological; Students; health care delivery; human; learning; mental health; psychological resilience; student},
	correspondence_address = {J.J. Mira; Atenea Research. FISABIO, Alicante, Spain; email: jose.mira@umh.es},
