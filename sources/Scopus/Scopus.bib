@ARTICLE{Merz2024,
	author = {Merz, Sibille and Aksakal, Tuğba and Hibtay, Ariam and Yücesoy, Hilâl and Fieselmann, Jana and Annaç, Kübra and Yılmaz-Aslan, Yüce and Brzoska, Patrick and Tezcan-Güntekin, Hürrem},
	title = {Racism against healthcare users in inpatient care: a scoping review},
