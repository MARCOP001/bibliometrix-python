@ARTICLE{Luo-Yng Tay2024,
	author = {Luo-Yng Tay, Kirsty and Cowan, George and Chatterji, Subarnarekha and Conti, Giulia and Speirs, Valerie},
	title = {Exploring the One Health Paradigm in Male Breast Cancer},
	year = {2024},
	journal = {Journal of Mammary Gland Biology and Neoplasia},
	volume = {29},
