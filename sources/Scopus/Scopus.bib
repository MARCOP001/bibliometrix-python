@ARTICLE{Myklebust2024,
	author = {Myklebust, Lars Henrik and Eide, Desiree and Arnevik, Espen A. and Dadras, Omid and De Pirro, Silvana and Ellefsen, Rune and Fadnes, Lars T. and Hesse, Morten and Kvamme, Timo L. and Melis, Francesca and Oldervoll, Ann and Thylstrup, Birgitte and Wusthoff, Linda E.C. and Clausen, Thomas},
