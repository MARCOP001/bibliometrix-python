@ARTICLE{Liu2024,
	author = {Liu, Xiaowen and Wang, Yanling and Ma, Li and Wang, Danhui and Peng, Zhihong and Mao, Zenghui},
	title = {High prevalence of erectile dysfunction in men with hyperthyroidism: a meta-analysis},
	year = {2024},
	journal = {BMC Endocrine Disorders},
	volume = {24},
	number = {1},
	doi = {10.1186/s12902-024-01585-6},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85191829168&doi=10.1186%2fs12902-024-01585-6&partnerID=40&md5=ed90926275c69699804e25228d2dabea},
	affiliations = {Hunan Provincial Key Laboratory of Regional Hereditary Birth Defects Prevention and Control, Changsha Hospital for Maternal & amp; Child Health Care, Hunan Normal University, Changsha, China; College of Health Science and Engineering, Hubei University, Wuhan, China},
	abstract = {Objective: The objective of this study was to evaluate the association between hyperthyroidism and the risk of developing erectile dysfunction (ED). Methods: A comprehensive search of multiple databases, including PubMed, Embase, Cochrane, and Web of Science, was conducted to identify relevant studies investigating the relationship between hyperthyroidism and ED in men. The quality of the included studies was assessed using the Newcastle‒Ottawa Quality Rating Scale, and a meta-analysis was performed using Stata 16.0 and RevMan 5.3 software. Results: A total of four papers encompassing 25,519 study subjects were included in the analysis. Among these, 6,429 individuals had hyperthyroidism, while 19,090 served as controls. The overall prevalence of ED in patients with hyperthyroidism was determined to be 31.1% (95% CI 0.06–0.56). In patients with uncomplicated hyperthyroidism, the incidence of ED was 21.9% (95% CI 0.05–0.38). The combined odds ratio (OR) for the four studies was 1.73 (OR: 1.73; 95% CI [1.46–2.04]; p <.00001). Conclusion: Our findings demonstrate a higher incidence of ED in patients with hyperthyroidism. These results provide valuable information for healthcare professionals and can facilitate discussions surrounding appropriate treatment options for ED in patients with hyperthyroidism. © The Author(s) 2024.},
	author_keywords = {Erectile dysfunction; Hyperthyroidism; Morbidity; Therapy},
	keywords = {Erectile Dysfunction; Humans; Hyperthyroidism; Male; Prevalence; Article; confidence interval; data base; disease association; erectile dysfunction; health care personnel; human; hyperthyroidism; incidence; morbidity; odds ratio; risk assessment; risk factor; systematic review; complication; erectile dysfunction; hyperthyroidism; male; meta analysis; prevalence},
