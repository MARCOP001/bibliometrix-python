	author = {Nabei, Jacob Nignan and Bonful, Harriet Affran and Afari, Edwin Andrews and Mohammed, Abdul Gafaru and Anum, Adote},
	title = {Predictors of quality of life of TB/HIV co-infected patients in the Northern region of Ghana},
	year = {2024},
	journal = {BMC Infectious Diseases},
