@ARTICLE{Catho2024,
	author = {Catho, Gaud and Fortchantre, Loïc and Teixeira, Daniel and Galas-Haddad, Murielle and Boroli, Filippo and Chraïti, Marie-Noëlle and Abbas, Mohamed and Harbarth, Stephan and Buetti, Niccolò},
