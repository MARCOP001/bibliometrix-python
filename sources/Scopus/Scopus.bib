	title = {Project CHARIOT: study protocol for a hybrid type 1 effectiveness-implementation study of comprehensive tele-harm reduction for engagement of people who inject drugs in HIV prevention services},
	year = {2024},
	journal = {Addiction Science and Clinical Practice},
	volume = {19},
