@ARTICLE{Dovizio2024,
	author = {Dovizio, Melania and Veronesi, Chiara and Bartolini, Fausto and Cavaliere, Arturo and Grego, Stefano and Pagliaro, Romina and Procacci, Cataldo and Ubertazzo, Loredana and Bertizzolo, Lorenzo and Muzii, Barbara and Parisi, Salvatore and Perrone, Valentina and Baraldi, Eugenio and Bozzola, Elena and Mosca, Fabio and Esposti, Luca Degli},
	title = {Clinical and economic burden of respiratory syncytial virus in children aged 0–5 years in Italy},
	year = {2024},
