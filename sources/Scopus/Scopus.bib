@ARTICLE{Ogugu2024,
	author = {Ogugu, Everlyne G. and Bidwell, Julie T. and Ruark, Allison and Butterfield, Rita M. and Weiser, Sheri D. and Neilands, Torsten B. and Mulauzi, Nancy and Rambiki, Ethel and Mkandawire, James and Conroy, Amy A.},
	title = {Barriers to accessing care for cardiometabolic disorders in Malawi: partners as a source of resilience for people living with HIV},
	year = {2024},
	journal = {International Journal for Equity in Health},
	volume = {23},
	number = {1},
	doi = {10.1186/s12939-024-02181-9},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85191620800&doi=10.1186%2fs12939-024-02181-9&partnerID=40&md5=bc393e199665f6f3e66bca04687a6a8e},
	affiliations = {Betty Irene Moore School of Nursing, University of California Davis, Davis, CA, United States; Wheaton College, Biological and Health Sciences, Wheaton, IL, United States; Department of Medicine, University of California San Francisco, San Francisco, CA, United States; Invest in Knowledge, Zomba, Malawi; Lighthouse Trust, Lilongwe, Malawi; Betty Irene Moore School of Nursing, University of California Davis, 2570 48th Street, Sacramento, 95817, CA, United States},
	abstract = {Background: People living with HIV (PLWH) are at increased risk of cardiometabolic disorders (CMD). Adequate access to care for both HIV and CMD is crucial to improving health outcomes; however, there is limited research that have examined couples’ experiences accessing such care in resource-constrained settings. We aimed to identify barriers to accessing CMD care among PLWH in Malawi and the role of partners in mitigating these barriers. Methods: We conducted a qualitative investigation of barriers to CMD care among 25 couples in Malawi. Couples were eligible if at least one partner was living with HIV and had hypertension or diabetes (i.e., the index patient). Index patients were recruited from HIV care clinics in the Zomba district, and their partners were enrolled thereafter. Interviews were conducted separately with both partners to determine barriers to CMD care access and how partners were involved in care. Results: Participants framed their experiences with CMD care by making comparisons to HIV treatment, which was free and consistently available. The main barriers to accessing CMD care included shortage of medications, cost of tests and treatments, high cost of transportation to health facilities, lengthy wait times at health facilities, faulty or unavailable medical equipment and supplies, inadequate monitoring of patients’ health conditions, some cultural beliefs about causes of illness, use of herbal therapies as an alternative to prescribed medicine, and inadequate knowledge about CMD treatments. Partners provided support through decision-making on accessing medical care, assisting partners in navigating the healthcare system, and providing financial assistance with transportation and treatment expenses. Partners also helped manage care for CMD, including communicating health information to their partners, providing appointment reminders, supporting medication adherence, and supporting recommended lifestyle behaviors. Conclusions: Couples identified many barriers to CMD care access, which were perceived as greater challenges than HIV care. Partners provided critical forms of support in navigating these barriers. With the rise of CMD among PLWH, improving access to CMD care should be prioritized, using lessons learned from HIV and integrated care approaches. Partner involvement in CMD care may help mitigate most barriers to CMD care. © The Author(s) 2024.},
	keywords = {Adult; Cardiovascular Diseases; Female; Health Services Accessibility; HIV Infections; Humans; Hypertension; Malawi; Male; Middle Aged; Qualitative Research; Resilience, Psychological; Malawi; Zomba; cost analysis; diabetes; health care; health risk; human immunodeficiency virus; hypertension; knowledge; lifestyle; mitigation; perception; adult; Article; cardiometabolic disorder; cardiometabolic risk; caregiver support; clinical article; cultural factor; diabetes mellitus; female; health belief; health care access; health care cost; help seeking behavior; HIV education; human; Human immunodeficiency virus infected patient; Human immunodeficiency virus infection; hypertension; lifestyle; Malawi; male; medication compliance; metabolic disorder; observational study; personnel management; psychological resilience; qualitative research; shared decision making; cardiovascular disease; complication; Human immunodeficiency virus infection; hypertension; middle aged; psychological resilience; psychology; qualitative research},
	correspondence_address = {E.G. Ogugu; Betty Irene Moore School of Nursing, University of California Davis, Davis, United States; email: egogugu@ucdavis.edu},
