@ARTICLE{Li2024,
	author = {Li, Shilin and Li, Xiang and Jiang, Sishi and Wang, Chenglin and Hu, Yingchun},
	title = {Identification of sepsis-associated mitochondrial genes through RNA and single-cell sequencing approaches},
	year = {2024},
	journal = {BMC Medical Genomics},
