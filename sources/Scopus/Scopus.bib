@ARTICLE{Rizan2024,
	author = {Rizan, Chantelle},
	title = {Environmental impact of hybrid (reusable/single-use) ports versus single-use equivalents in robotic surgery},
	year = {2024},
	journal = {Journal of Robotic Surgery},
	volume = {18},
	number = {1},
	doi = {10.1007/s11701-024-01899-6},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85189209646&doi=10.1007%2fs11701-024-01899-6&partnerID=40&md5=7b4639fe9c09160ea7e6f71e3ec83f26},
	affiliations = {Brighton and Sussex Medical School, Department of Global Health and Infection, Brighton, United Kingdom},
	abstract = {Given the rise in robotic surgery, and parallel movement towards net zero carbon, sustainable healthcare systems, it is important that the environmental impact of robotic approaches is minimised. The majority of greenhouse gas emissions associated with robotic surgery have previously been associated with single-use items. Whilst switching from single-use products to hybrid equivalents (predominantly reusable, with a small single-use component) has previously been found to reduce the environmental impact of a range of products used for laparoscopic surgery, the generalisability of this to robotic surgery has not previously been demonstrated. In this life cycle assessment, use of hybrid 5 mm ports compatible with emerging robotic systems (143 g CO2e) was found to reduce the carbon footprint by 83% compared with using single-use equivalents (816 g CO2e), accompanied by reductions in fifteen out of eighteen midpoint environmental impact categories. For endpoint categories, there was an 81% reduction in impact on human health and species loss, and 82% reductions in resource depletion associated with using hybrid robotic 5 mm ports. Whilst the carbon footprint of 5 mm hybrid ports compatible with emerging robotic equipment was 70% higher than previous estimates of ports appropriate for conventional laparoscopic approaches, the six-fold reductions seen with hybrids in this analysis point to the generalisability of the finding that reusable or hybrid products have a lower carbon footprint when compared with single-use equivalents. Surgeons, procurement teams, and policy makers should encourage innovation towards clinically safe and effective robotic instruments with maximal reusable components. © The Author(s), under exclusive licence to Springer-Verlag London Ltd., part of Springer Nature 2024.},
	author_keywords = {Ports; Reusable; Robotic surgery; Sustainability},
	keywords = {Environment; Humans; Movement; Robotic Surgical Procedures; Robotics; Surgeons; Artificial life; Emission control; Gas emissions; Greenhouse gases; Laparoscopy; Life cycle; Robotic surgery; Sustainable development; % reductions; Greenhouse gas emissions; Healthcare systems; Laparoscopic surgery; Port; Reusable; Robotic systems; Robotics surgery; Single use; Zero carbons; carbon footprint; ecosystem; environmental impact; fluid intake; fossil resource scarcity; greenhouse effect; health impact; human; land use; laparoscopic surgery; Letter; life cycle assessment; mineral resource scarcity; resource depletion  reductions; robot assisted surgery; species loss; environment; movement (physiology); procedures; robotics; surgeon; Carbon footprint},
	correspondence_address = {C. Rizan; Brighton and Sussex Medical School, Department of Global Health and Infection, Brighton, United Kingdom; email: c.t.rizan@bsms.ac.uk},
	publisher = {Springer Nature},
